# ── LLM Provider (at least one required) ──────────────────────────────
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-large-latest

# Optional alternative providers (all go through LiteLLM)
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# GEMINI_API_KEY=your-gemini-api-key-here

# ── Per-agent model overrides (default: MISTRAL_MODEL) ────────────────
RESEARCH_MODEL=mistral-large-latest
PLANNING_MODEL=mistral-large-latest
WRITING_MODEL=mistral-large-latest
EDITING_MODEL=mistral-large-latest
OPTIMIZATION_MODEL=mistral-small-latest
ORCHESTRATOR_MODEL=mistral-large-latest

# ── Service URLs ──────────────────────────────────────────────────────
LIGHTRAG_URL=http://lightrag:9621
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/acs
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── Host / Port ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
FRONTEND_PORT=3000
